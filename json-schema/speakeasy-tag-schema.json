{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Tag",
  "title": "Tag",
  "properties": {
    "id": {
      "type": "string",
      "description": "Format {namespace_id}/{tag}"
    },
    "name": {
      "type": "string",
      "description": "Human readable tag name"
    },
    "namespace_name": {
      "type": "string"
    },
    "revision_digest": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "name",
    "namespace_name",
    "revision_digest"
  ]
}