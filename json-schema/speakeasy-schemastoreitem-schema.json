{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SchemaStoreItem",
  "title": "SchemaStoreItem",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "spec": {
      "type": "string"
    },
    "packageName": {
      "type": "string"
    },
    "sdkClassname": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "format": {
      "type": "string",
      "enum": [
        "json",
        "yaml"
      ]
    }
  },
  "required": [
    "id",
    "spec",
    "created_at",
    "format",
    "packageName",
    "sdkClassname"
  ]
}