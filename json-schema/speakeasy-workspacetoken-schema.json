{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/WorkspaceToken",
  "title": "WorkspaceToken",
  "description": "A workspace token",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "alg": {
      "type": "string"
    },
    "key": {
      "type": "string"
    },
    "last_used": {
      "nullable": true,
      "type": "string",
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "nullable": true
    },
    "created_by_name": {
      "type": "string",
      "nullable": true
    },
    "created_by_photo_url": {
      "type": "string",
      "nullable": true
    },
    "email": {
      "nullable": true,
      "type": "string"
    }
  },
  "required": [
    "id",
    "name",
    "alg",
    "key",
    "created_at",
    "workspace_id"
  ]
}